<script is:inline>
  // ブロッキングスクリプト: DOMが表示される前にアニメーション設定を適用
  (function () {
    const animation = localStorage.getItem("animation");
    const isReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (animation === "stop" || (animation === null && isReduced)) {
      document.documentElement.classList.add("stop");
    }
  })();
</script>

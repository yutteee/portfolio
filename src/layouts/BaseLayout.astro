---
import "destyle.css";
import { Header } from "../features/Header";
import type { CurrentPage } from "../features/Header/presenter";
import { Footer } from "../features/Footer";
import "../styles/global.css";
import { SEO } from "astro-seo";
import { SITE_URL } from "../consts";
import AnimationScript from "../components/AnimationScript.astro";
import CommonHead from "../components/CommonHead.astro";

interface Props {
  title: string;
  description: string;
  ogpType?: "website" | "article";
}

const { title, description, ogpType = "website" } = Astro.props;
---

<html lang="ja">
  <head>
    <AnimationScript />
    <CommonHead />
    <SEO
      charset="UTF-8"
      title={`${title} | yutteee-portfolio`}
      description={description}
      openGraph={{
        basic: {
          title: `${title} | yutteee-portfolio`,
          type: "article",
          image: `${SITE_URL}/portfolio.png`,
        },
        image: {
          alt: "中村優作のポートフォリオ",
        },
      }}
      extend={{
        meta: [
          {
            name: "twitter:card",
            content: "summary_large_image",
          },
        ],
      }}
    />
  </head>
  <body>
    <Header currentPage={title as CurrentPage} client:load />
    <slot />
    <Footer client:only />
  </body>
</html>

---
import type { CollectionEntry } from "astro:content";
import type { MarkdownInstance } from "astro";
import { SITE_URL } from "../../../../consts";
import TableOfContents from "./TableOfContents.astro";
import Comments from "../Comments.astro";
import "./content.css";

interface Props {
  post: CollectionEntry<"posts">;
  Content: MarkdownInstance<Record<string, unknown>>["Content"];
  headings: { depth: number; slug: string; text: string }[];
}

const { post, Content, headings } = Astro.props;
---

<div class="wrapper">
  <div class="title-wrapper">
    <div class="post-meta">
      <span>{post.data.pubDate}</span>
    </div>
    <h1 class="title">{post.data.title}</h1>
    {
      post.data.image ? (
        <img
          src={post.data.image.url}
          alt={post.data.image.alt}
          width="720"
          height="378"
          class="image"
        />
      ) : (
        <img
          src={`${SITE_URL}/ogp/${post.id.replace(/\/index$/, "")}.png`}
          alt=""
          width="720"
          height="378"
          class="image"
        />
      )
    }
  </div>

  <TableOfContents headings={headings} />

  <div class="main-wrapper">
    <Content />
  </div>
</div>

<Comments />

<style>
  .wrapper {
    display: grid;
    gap: var(--space-l);
    width: 100%;
    margin: 0 auto;
    padding-top: var(--space-l);
    align-items: start;

    /* SP: 縦1列 (title -> toc -> content) */
    grid-template-columns: 1fr;
    grid-template-areas:
      "title"
      "toc"
      "content";
    max-width: var(--text-max-width);

    /* PC: 2カラム (title が上に跨ぐ, content左 + toc右)
       wrapper max は: text-max-width + (content padding * 2 + grid gap) * space-l + TOC */
    @media screen and (min-width: 1025px) /* sync with --bp-md-plus */ {
      grid-template-columns: 1fr 360px;
      grid-template-areas:
        "title title"
        "content toc";
      max-width: calc(var(--text-max-width) + var(--space-l) * 3 + 360px);
    }

    .title-wrapper {
      grid-area: title;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-s);
      width: 100%;
      max-width: var(--text-max-width);
      margin: 0 auto;

      .post-meta {
        display: flex;
        align-items: center;
        gap: var(--space-s);
      }

      .slide-badge {
        background-color: var(--color-link);
        color: var(--color-text-inverse);
        padding: var(--space-3xs) var(--space-2xs);
        border-radius: var(--radius-sm);
        font-size: var(--step--1);
        font-weight: bold;
      }

      .title {
        font-size: var(--step-2);
        font-weight: 900;
      }

      .image {
        width: 100%;
        height: auto;
        aspect-ratio: 720 / 378;
        object-fit: cover;
        border: 8px solid var(--color-surface);
        border-radius: var(--radius-md);
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }
    }
  }
</style>

---
// TODO: この詳細ページはMarkdown移行PRで暫定作成。デザイン・実装を別途検討する
import { SEO } from "astro-seo";
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((product: CollectionEntry<"products">) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);

import "destyle.css";
import "../../styles/global.css";
import { Header } from "../../features/Header";
import { Footer } from "../../features/Footer";
import ProductPost from "./_components/ProductPost/index.astro";
import { Icon } from "astro-icon/components";
import CommonHead from "../../components/CommonHead.astro";
---

<!doctype html>
<html lang="ja">
  <head>
    <CommonHead />
    <SEO
      charset="UTF-8"
      title={`${product.data.title} | yutteee-portfolio`}
      description={product.data.description}
      openGraph={{
        basic: {
          title: product.data.title,
          type: "article",
          image: `${import.meta.env.PUBLIC_SITE_URL}${product.data.image.url}`,
        },
        image: {
          alt: product.data.image.alt,
        },
      }}
    />
  </head>
  <body>
    <Header currentPage="プロダクト" client:load />
    <main class="container">
      <div class="breadcrumbs">
        <a href="/">トップ</a>
        <Icon name="weui:arrow-outlined" />
        <a href="/products">プロダクト</a>
        <Icon name="weui:arrow-outlined" />
        <div>{product.data.title}</div>
      </div>

      <ProductPost product={product} Content={Content} />
    </main>
    <Footer client:only />

    <style>
      .container {
        width: 100%;
        max-width: 90rem;
        margin: 0 auto;
        padding: var(--space-3xl) var(--space-s);
      }
      .breadcrumbs {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--space-2xs);
        padding: var(--space-2xs) var(--space-s);
        background-color: var(--color-white);
        height: fit-content;
        width: fit-content;
        border-radius: var(--radius-infinity);

        @media screen and (max-width: 1024px) /* sync with --bp-md */ {
          width: 100%;
        }

        a {
          color: var(--color-link);
          text-decoration: underline;
        }
      }
    </style>
  </body>
</html>

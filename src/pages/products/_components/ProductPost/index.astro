---
import type { CollectionEntry } from "astro:content";
import { FiLink, FiGithub } from "react-icons/fi";
import { Button } from "../../../../ui/Button";
import "../../../posts/_components/BlogPost/content.css";

interface Props {
  product: CollectionEntry<"products">;
  // biome-ignore lint/suspicious/noExplicitAny: <explanation>
  Content: any;
}

const { product, Content } = Astro.props;
---

<div class="wrapper">
  <div class="title-wrapper">
    <div class="post-meta">
      <span>{product.data.period}</span>
    </div>
    <h1 class="title">{product.data.title}</h1>
    <p class="description">{product.data.description}</p>

    <div class="image-container">
      <img
        src={product.data.image.url}
        alt={product.data.image.alt}
        width="720"
        height="450"
        class="image"
      />
    </div>

    <div class="links">
      {
        product.data.url && (
          <Button
            href={product.data.url}
            target="_blank"
            rel="noopener noreferrer"
            startIcon={FiLink}
          >
            サイト
          </Button>
        )
      }
      {
        product.data.github && (
          <Button
            href={product.data.github}
            target="_blank"
            rel="noopener noreferrer"
            startIcon={FiGithub}
          >
            GitHub
          </Button>
        )
      }
    </div>

    {
      product.data.tech && product.data.tech.length > 0 && (
        <div class="tech-stack">
          {product.data.tech.map((t: string) => (
            <span class="tech-badge">{t}</span>
          ))}
        </div>
      )
    }
  </div>

  <div class="main-wrapper">
    <Content />
  </div>
</div>

<style>
  .wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
    width: 100%;
    max-width: var(--text-max-width);
    margin: 0 auto;
    padding-top: var(--space-l);

    /* PC では content.css の padding 分（space-l * 2）を加味して text 領域が text-max-width に届くようにする */
    @media screen and (min-width: 1025px) /* sync with --bp-md-plus */ {
      max-width: calc(var(--text-max-width) + var(--space-l) * 2);
    }
  }

  .title-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-s);
    width: 100%;

    .post-meta {
      font-size: var(--step--1);
      color: var(--color-text);
      opacity: 0.6;
    }

    .title {
      font-size: var(--step-2);
      font-weight: 900;
      text-align: center;
    }

    .description {
      font-size: var(--step-0);
      text-align: center;
    }
  }

  .image-container {
    width: 100%;

    .image {
      width: 100%;
      height: auto;
      aspect-ratio: 720 / 450;
      object-fit: cover;
      border: 8px solid var(--color-surface);
      border-radius: var(--radius-md);
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }
  }

  .links {
    display: flex;
    gap: var(--space-s);
    flex-wrap: wrap;
    justify-content: center;
  }

  .tech-stack {
    display: flex;
    gap: var(--space-2xs);
    flex-wrap: wrap;
    justify-content: center;
  }

  .tech-badge {
    padding: var(--space-3xs) var(--space-xs);
    background-color: var(--color-surface);
    border-radius: var(--radius-infinity);
    font-size: var(--step--1);
  }
</style>
